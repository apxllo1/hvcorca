{
    "name": "Havoc",
    "globIgnorePaths": [
        "**/package.json",
        "**/tsconfig.json",
        "**/src/**",
        "**/*.spec.lua",
        "**/*.d.lua"
    ],
    "tree": {
        "$className": "DataModel",
        "Havoc": {
            "$path": "out",
            "include": {
                "$path": "include",
                "node_modules": {
                    "$path": "node_modules/@rbxts"
                }
            }
        }
    }
}
